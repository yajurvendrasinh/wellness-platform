  "_meta": {
    "sources": [
      "Cardio Made Simple — Dr. Mike Israetel & Max Weisenthal (RP, 2023)",
      "The Naked Warrior — Pavel Tsatsouline (Dragon Door, 2004)"
    ],
    "structure": "level → duration_min → { meta, variants: [A, B, C] }",
    "levels": ["beginner", "intermediate", "expert"],
    "durations_min": [30, 60, 90],
    "total_combinations": 9,
    "variants_per_combination": 3,
    "key_concepts": {
      "SFTR": "Stimulus to Fatigue and Time Ratio — the primary metric for evaluating cardio efficiency. Maximize calorie burn while minimizing fatigue and session duration.",
      "intensity_zones": {
        "Zone_1_recovery": "<110 bpm — too low for meaningful cardiovascular stimulus; acceptable only for active rest",
        "Zone_2_optimal": "110–150 bpm — RP's recommended sweet spot; all health benefits, minimal fatigue accumulation",
        "Zone_3_hard": "150–170 bpm — acceptable 1–3x/week; significantly higher fatigue cost",
        "Zone_4_max": ">170 bpm — reserved for brief HIIT intervals only; high joint and systemic fatigue"
      },
      "GTG_conditioning": "Grease the Groove principle (Naked Warrior): practice movement patterns frequently at sub-maximal intensity (≤50% of max effort), never to failure. Applied to bodyweight conditioning circuits this means: short sets, high frequency, full neural freshness every set.",
      "optimal_modalities": ["Elliptical (120–140 bpm)", "Incline treadmill walk (3+ mph, 5–10% grade)", "Step tracking (10,000–14,000/day)", "Outdoor brisk walk", "Rowing machine", "Bodyweight conditioning circuits"],
      "suboptimal_modalities": ["Reclined stationary bike", "Slow flat treadmill walking (holding rails)", "Swimming (unless proficient)", "High-impact HIIT every session"],
      "progression_system": {
        "beginner": "Increase duration before intensity. Build to consistent 10,000 daily steps. Add dedicated sessions when steps average below 10,000.",
        "intermediate": "Autoregulated intensity by feel and bpm. Add 1–2 HIIT sessions per week maximum. Increase step goal toward 12,000–14,000 during fat loss phases.",
        "expert": "Periodize cardio by phase: more during fat loss (up to 14,000 steps + dedicated sessions), maintenance during muscle gain. Use hungry/tired decision framework to adjust cardio vs. food deficit split."
      },
      "bpm_guidance": "Stay 110–150 bpm for most sessions. Hard sessions (>150) require 2–3 easier days to recover. Monitor joint health — back off intensity at first sign of knee/ankle discomfort.",
      "fat_loss_formula": "cardio_deficit_cals = total_daily_deficit × 0.5. Food reduction covers the other 50%.",
      "maintenance_formula": "session_calorie_target = 2.5 × bodyweight_lbs. Perform 5x/week if steps average <3,000/day."
    }
  },

